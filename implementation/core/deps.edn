;; day8/re-frame-2 — core artefact (rf2-0hxm).
;;
;; Per Spec 006 §Substrate-adapter shipping convention: substrate adapters
;; ship as separate Maven artefacts; this is the core (registry, drain,
;; machines, flows, routing, fx, trace) and excludes substrate-specific
;; code. The Reagent adapter lives in implementation/reagent/. Per
;; rf2-p7va (the first per-feature split per rf2-5vjj Strategy B) the
;; Spec 010 schema-attachment surface lives in implementation/schemas/
;; (`day8/re-frame-2-schemas`).
;;
;; Reagent appears as a dependency here because re-frame.views (CLJS-only
;; reg-view) is currently Reagent-coupled per Spec 006 §CLJS reference
;; scope. Per the rf2-0hxm decision, that coupling is preserved at the
;; views.cljs layer; the *substrate* adapter ns (re-frame.substrate.reagent)
;; lives in the Reagent artefact. The full substrate-config plumbing
;; unification is deferred to rf2-3yij (UIx adapter).
;;
;; metosin/malli is intentionally NOT a dep of this artefact: per
;; rf2-p7va the schemas artefact owns the Malli relationship. The
;; runtime resolves of `malli.core/validate` in `re-frame.epoch` and
;; `re-frame.http-managed` are intentional best-effort `(resolve ...)`
;; calls that no-op when Malli is absent — apps that opt into managed
;; HTTP decode-schemas or epoch-restore schema validation pull in the
;; schemas artefact (which carries Malli) alongside core.
{:paths ["src"]
 :deps  {org.clojure/clojure       {:mvn/version "1.11.1"}
         org.clojure/clojurescript {:mvn/version "1.11.132"}
         reagent/reagent           {:mvn/version "2.0.1"}}

 :aliases
 {;; The core artefact's tests historically exercised schema-aware
  ;; paths (every reset-runtime fixture rolled the per-frame schema
  ;; registry; many test files require re-frame.schemas to set up their
  ;; data shapes). Per rf2-p7va those tests stay in core/test/ and
  ;; pull schemas in as a test-only dep — so the core artefact's test
  ;; classpath includes schemas (and its Malli dep) while the
  ;; published library jar carries neither. Keeps the per-test
  ;; coverage intact without smuggling schemas into the production
  ;; classpath. See implementation/schemas/deps.edn.
  :test {:extra-paths ["test" "../../examples"]
         :extra-deps  {day8/re-frame-2-schemas {:local/root "../schemas"}
                       io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]}

  ;; Clojars deploy (rf2-r382). Modeled on re-frame v1's release flow:
  ;; the release workflow runs `clojure -M:clein deploy` from this
  ;; artefact's directory, which builds pom + jar and pushes to Clojars
  ;; using CLOJARS_USERNAME / CLOJARS_PASSWORD env vars.
  :clein {:extra-deps {io.github.noahtheduke/clein
                       {:git/url "https://github.com/day8/clein.git"
                        :git/sha "2b83503246e8291fc023d688574640a9b23d8c50"}}
          :main-opts  ["-m" "noahtheduke.clein"]}

  ;; Build descriptor consumed by clein. Per-artefact: this builds the
  ;; `day8/re-frame-2` core artefact. The Reagent adapter has its own
  ;; build descriptor in implementation/reagent/deps.edn.
  ;;
  ;; :version is a relative path to the repo-root VERSION file — single
  ;; source of truth for both artefacts. Mike updates VERSION in the
  ;; release commit, then tags `v<contents>` (e.g. `v0.0.1.beta`).
  :clein/build
  {:lib      day8/re-frame-2
   :main     re-frame.core
   :url      "https://github.com/day8/re-frame2"
   :version  "../../VERSION"
   :license  {:name "MIT"
              :url  "https://opensource.org/licenses/MIT"}
   :src-dirs ["src"]}}}
