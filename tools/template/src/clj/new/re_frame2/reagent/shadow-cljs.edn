;; {{name}} — shadow-cljs build config (Reagent substrate).
;;
;; Two builds:
;;   :app  — watch / release. Compiles to resources/public/js/main.js.
;;           Boot entry point: {{namespace}}.core/init.
;;   :test — node-side test runner. Picks up any *_test.cljs file under
;;           test/ and runs it via cljs.test.
{:deps   {:aliases [:shadow]}
 :source-paths ["src" "test" "dev"]

 :dev-http {8280 "resources/public"}

 :builds
 {:app
  {:target     :browser
   :output-dir "resources/public/js"
   :asset-path "/js"
   :modules    {:main {:init-fn {{namespace}}.core/init}}
   ;; :devtools/preloads loads day8.re-frame2-causa.preload before the
   ;; :init-fn fires — registers the Ctrl+Shift+C keybinding, mounts
   ;; the empty Causa shell, and subscribes the trace bus. Cut from
   ;; release builds automatically (preloads only run under :watch /
   ;; :compile :app, never under :release).
   :devtools   {:after-load {{namespace}}.core/init
                :preloads   [day8.re-frame2-causa.preload]}}

  :test
  {:target    :node-test
   :output-to "out/node-test.js"
   :ns-regexp "-test$"}}}
