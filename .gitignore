# Clojure / CLJS
/.cpcache/
**/.cpcache/
/.shadow-cljs/
/target/
/out/
/classes/
/node_modules/
*.log
pom.xml

# OS / editors
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
*.iml

# Local dev
.env
.env.local
.envrc

# AI working tree (local-only — findings, map, super-prompt playground)
# Per docs/the-mayor-method.md
/ai/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# MkDocs build artefacts (rf2-h09k)
/site/
# spec/ is staged into docs/spec/ at build time; never commit the staged copy.
/docs/spec/
# Python bytecode from mkdocs_hooks.py (rf2-qvlf) and scripts/ (rf2-sefq).
/__pycache__/
**/__pycache__/

# Skills build artefacts
skills/*/node_modules/
skills/*/.shadow-cljs/
skills/*/out/
skills/*/target/

# clj-kondo cache (rf2-mfi1s) — config.edn at /.clj-kondo/ is checked in;
# the cache subdir is regenerated per-machine.
/.clj-kondo/.cache/
/.clj-kondo/.cache-version

# Orphan npm lockfile (rf2-mfi1s) — there is no repo-root package.json;
# this guards against stray `npm` invocations from the wrong cwd.
/package-lock.json

# CDP scratch dir from examples/ test runs (rf2-mfi1s) — local Chrome
# user-data-dir, never committed.
/examples/.edge-cdp/

# Local worktrees created by EnterWorktree tool (rf2-mfi1s) — agent
# scratch space, local-only.
/.claude/worktrees/
